# NEXTGEN Frontend - Environment Variables Example
# Copy this file to .env and update with your local configuration

# WordPress API URL
VITE_WP_API_URL=http://wp-nexgen.local/wp-json
VITE_WP_SITE_URL=http://wp-nexgen.local

# Frontend URL
VITE_APP_URL=http://localhost:5173

# API Endpoints
VITE_API_NAMESPACE=nextgen/v1
VITE_WP_NAMESPACE=wp/v2

# Mode
VITE_APP_MODE=development

# Enable Debug
VITE_DEBUG=true
